{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:membrane-vqc:schema:report:1.1",
  "title": "Membrane Visual QC planar single-structure review report",
  "type": "object",
  "required": ["schema_version", "report_type", "software", "runtime", "input", "orientation", "parameters", "summary", "review_items", "ligand_neighbours", "warnings", "limitations"],
  "$defs": {
    "vector3": {"type": "array", "prefixItems": [{"type": "number"}, {"type": "number"}, {"type": "number"}], "minItems": 3, "maxItems": 3},
    "depthFields": {"type": "object", "required": ["signed_distance", "absolute_center_distance", "nearest_boundary_distance", "outside_distance", "normalized_depth"], "properties": {"signed_distance": {"type": "number"}, "absolute_center_distance": {"type": "number", "minimum": 0}, "nearest_boundary_distance": {"type": "number", "minimum": 0}, "outside_distance": {"type": "number", "minimum": 0}, "normalized_depth": {"oneOf": [{"type": "number", "minimum": 0, "maximum": 1}, {"type": "null"}]}}}
  },
  "properties": {
    "schema_version": {"const": "1.1"},
    "report_type": {"const": "single_structure_review"},
    "software": {"type": "object", "required": ["name", "version", "commit", "commit_status"], "properties": {"name": {"const": "membrane-vqc-pymol"}, "version": {"type": "string"}, "commit": {"type": "string"}, "commit_status": {"enum": ["recorded", "unavailable"]}}},
    "runtime": {"type": "object", "required": ["python", "pymol", "pymol_status", "platform"], "properties": {"python": {"type": "string"}, "pymol": {"type": "string"}, "pymol_status": {"enum": ["recorded", "unavailable"]}, "platform": {"type": "string"}}},
    "input": {"type": "object", "required": ["path", "sha256", "selection", "format", "structure_source", "structure_type", "provenance_status"], "properties": {"path": {"type": "string"}, "sha256": {"type": "string", "pattern": "^$|^[a-f0-9]{64}$"}, "selection": {"type": "string", "minLength": 1}, "format": {"type": "string"}, "structure_source": {"type": "string"}, "structure_type": {"type": "string"}, "provenance_status": {"enum": ["file_hashed", "input_path_not_supplied"]}}},
    "orientation": {"type": "object", "required": ["source", "source_version", "geometry", "center", "normal", "lower_offset", "upper_offset", "interface_width", "parameters", "warnings"], "properties": {"source": {"type": "string", "minLength": 1}, "source_version": {"type": ["string", "null"]}, "confidence": {"type": ["string", "null"]}, "geometry": {"const": "planar"}, "center": {"$ref": "#/$defs/vector3"}, "normal": {"$ref": "#/$defs/vector3"}, "lower_offset": {"type": "number"}, "upper_offset": {"type": "number"}, "interface_width": {"type": "number", "minimum": 0}, "metadata": {"type": "object"}, "parameters": {"type": "object"}, "warnings": {"type": "array", "items": {"type": "string"}}, "import": {"type": "object", "required": ["path", "sha256", "schema_version"], "properties": {"path": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "schema_version": {"const": "1.0"}}, "additionalProperties": false}}},
    "parameters": {"type": "object"},
    "summary": {"type": "object", "required": ["overall_status"], "properties": {"overall_status": {"enum": ["NO_FLAGS", "REVIEW_ITEMS", "INSUFFICIENT_CONTEXT", "ANALYSIS_ERROR"]}}},
    "review_items": {"type": "array", "items": {"allOf": [{"$ref": "#/$defs/depthFields"}, {"type": "object", "required": ["model", "chain", "resi", "resn", "classification", "severity", "reason", "z"], "properties": {"model": {"type": "string"}, "chain": {"type": "string"}, "resi": {"type": "string"}, "resn": {"type": "string"}, "classification": {"const": "core"}, "severity": {"enum": ["WARNING", "INSPECT"]}, "reason": {"type": "string", "minLength": 1}, "z": {"type": "number"}}}]}},
    "ligand_neighbours": {"type": "array", "items": {"$ref": "#/$defs/depthFields"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}
